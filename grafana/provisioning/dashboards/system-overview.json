{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "System Architecture",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## Multi-Agent AI Rate-Limited System\nClient -> API Gateway (Go) -> Rate Limiter (Java) -> Dragonfly (Redis) -> AI Worker (Python) -> AI Provider"
      }
    },
    {
      "title": "Dragonfly Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 3 },
      "targets": [
        { "expr": "api_gateway_dragonfly_up", "legendFormat": "Dragonfly", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Healthy", "color": "green" } } }]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center" }
    },
    {
      "title": "Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 3 },
      "targets": [
        { "expr": "api_gateway_active_connections", "legendFormat": "Active", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } }
      }
    },
    {
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 3 },
      "targets": [
        { "expr": "api_gateway_queue_depth", "legendFormat": "Gateway", "refId": "A" },
        { "expr": "ai_worker_queue_depth", "legendFormat": "Worker", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } }
      }
    },
    {
      "title": "Workers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 3 },
      "targets": [
        { "expr": "ai_worker_active", "legendFormat": "Active", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }
      }
    },
    {
      "title": "Rate Limit Hits",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 3 },
      "targets": [
        { "expr": "sum(api_gateway_rate_limit_hits_total)", "legendFormat": "Gateway", "refId": "A" },
        { "expr": "sum(ai_worker_rate_limit_hits_total)", "legendFormat": "Worker", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 3 },
      "targets": [
        { "expr": "sum(rate(api_gateway_error_total[$__rate_interval])) / sum(rate(api_gateway_request_latency_seconds_count[$__rate_interval]))", "legendFormat": "Error %", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } },
        "overrides": []
      }
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        { "expr": "sum(rate(api_gateway_request_latency_seconds_count[$__rate_interval]))", "legendFormat": "requests/s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Job Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        { "expr": "rate(ai_worker_jobs_processed_total[$__rate_interval])", "legendFormat": "Processed", "refId": "A" },
        { "expr": "rate(ai_worker_jobs_failed_total[$__rate_interval])", "legendFormat": "Failed", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Latency p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(api_gateway_request_latency_seconds_bucket[$__rate_interval])))", "legendFormat": "gateway p95", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "429s & Retries",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        { "expr": "rate(api_gateway_upstream_429_total[$__rate_interval])", "legendFormat": "429s/s", "refId": "A" },
        { "expr": "rate(api_gateway_upstream_retries_total[$__rate_interval])", "legendFormat": "Retries/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent-rate-limit", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
