{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Masked Requests (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(increase(api_gateway_mask_requests_total[24h])) or vector(0)", "legendFormat": "Total", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] }
        }
      }
    },
    {
      "title": "Secrets Detected (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(increase(api_gateway_secrets_detected_total[24h])) or vector(0)", "legendFormat": "Secrets", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] }
        }
      }
    },
    {
      "title": "PII Detected (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(increase(api_gateway_pii_detected_total[24h])) or vector(0)", "legendFormat": "PII", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] }
        }
      }
    },
    {
      "title": "Mask Duration p95",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(api_gateway_mask_duration_seconds_bucket[$__rate_interval]))", "legendFormat": "p95", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 3,
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] }
        }
      }
    },
    {
      "title": "Secrets Detected by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 40, "showPoints": "never", "spanNulls": true, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (type) (rate(api_gateway_secrets_detected_total[$__rate_interval]))", "legendFormat": "{{type}}", "refId": "A" }
      ]
    },
    {
      "title": "PII Detected by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 40, "showPoints": "never", "spanNulls": true, "stacking": { "mode": "normal" } },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (type) (rate(api_gateway_pii_detected_total[$__rate_interval]))", "legendFormat": "{{type}}", "refId": "A" }
      ]
    },
    {
      "title": "Mask Duration by Phase (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, phase) (rate(api_gateway_mask_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{phase}} p95", "refId": "A" }
      ]
    },
    {
      "title": "Mask Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme-warm" },
          "custom": { "hideZeroBuckets": false },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (le) (rate(api_gateway_mask_duration_seconds_bucket{phase=\"secrets_detect\"}[$__rate_interval]))", "legendFormat": "{{le}}", "refId": "A" }
      ]
    },
    {
      "title": "Masked vs Unmasked (Secrets)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (has_secrets) (rate(api_gateway_mask_requests_total[$__rate_interval]))", "legendFormat": "secrets={{has_secrets}}", "refId": "A" }
      ]
    },
    {
      "title": "PII Masked vs Clean",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "showPoints": "never", "spanNulls": true },
          "unit": "ops"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (has_pii) (rate(api_gateway_mask_requests_total[$__rate_interval]))", "legendFormat": "pii={{has_pii}}", "refId": "A" }
      ]
    },
    {
      "title": "Top Secret Types (24h)",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "targets": [
        { "expr": "topk(10, sum by (type) (increase(api_gateway_secrets_detected_total[24h])))", "legendFormat": "{{type}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "orientation": "horizontal", "groupWidth": 0.7, "barWidth": 0.5 }
    },
    {
      "title": "Top PII Types (24h)",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "targets": [
        { "expr": "topk(10, sum by (type) (increase(api_gateway_pii_detected_total[24h])))", "legendFormat": "{{type}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "orientation": "horizontal", "groupWidth": 0.7, "barWidth": 0.5 }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent-rate-limit", "privacy"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "title": "PasteGuard - Data Privacy",
  "uid": "arl-pasteguard",
  "version": 1
}
