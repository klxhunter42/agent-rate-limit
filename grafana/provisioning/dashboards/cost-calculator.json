  "panels": [
    {
      "title": "AI API Cost Estimator",
      "type": "text",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## AI API Cost Estimator\n| Model | Input (per 1M tokens) | Output (per 1M tokens) |\n|-------|----------------------|------------------------|\n| glm-5.1 | $1.40 | $4.40 |\n| glm-5-turbo | $1.20 | $4.00 |\n| glm-5 | $1.00 | $3.20 |\n| glm-4.7 / glm-4.6 / glm-4.5 | $0.60 | $2.20 |\n| glm-4.7-flashx | $0.07 | $0.40 |\n| glm-4.5-x | $2.20 | $8.90 |\n| glm-4.5-air | $0.20 | $1.10 |\n| glm-4.5-airx | $1.10 | $4.50 |"
      }
    },
    {
      "title": "Actual Cost (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum(increase(api_gateway_cost_total[24h])) or vector(0)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "title": "Est. Cost from Tokens (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 4
      },
      "targets": [
        {
          "expr": "((sum(increase(api_gateway_token_input_total{model=~\"glm-5.1|glm-5-turbo|glm-5\"}[24h])) or vector(0)) * 1.0 + (sum(increase(api_gateway_token_output_total{model=~\"glm-5.1|glm-5-turbo|glm-5\"}[24h])) or vector(0)) * 3.2 + (sum(increase(api_gateway_token_input_total{model=~\"glm-4.7|glm-4.6|glm-4.5\"}[24h])) or vector(0)) * 0.6 + (sum(increase(api_gateway_token_output_total{model=~\"glm-4.7|glm-4.6|glm-4.5\"}[24h])) or vector(0)) * 2.2 + (sum(increase(api_gateway_token_input_total{model=\"glm-4.7-flashx\"}[24h])) or vector(0)) * 0.07 + (sum(increase(api_gateway_token_output_total{model=\"glm-4.7-flashx\"}[24h])) or vector(0)) * 0.4 + (sum(increase(api_gateway_token_input_total{model=\"glm-4.5-x\"}[24h])) or vector(0)) * 2.2 + (sum(increase(api_gateway_token_output_total{model=\"glm-4.5-x\"}[24h])) or vector(0)) * 8.9 + (sum(increase(api_gateway_token_input_total{model=\"glm-4.5-air\"}[24h])) or vector(0)) * 0.2 + (sum(increase(api_gateway_token_output_total{model=\"glm-4.5-air\"}[24h])) or vector(0)) * 1.1 + (sum(increase(api_gateway_token_input_total{model=\"glm-4.5-airx\"}[24h])) or vector(0)) * 1.1 + (sum(increase(api_gateway_token_output_total{model=\"glm-4.5-airx\"}[24h])) or vector(0)) * 4.5) / 1000000",
          "legendFormat": "Est. Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
