{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Cost Calculator - AI API Usage",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## AI API Cost Estimator\nEstimate costs based on actual token usage from the gateway.\n\n| Provider | Model | Input (per 1M tokens) | Output (per 1M tokens) |\n|----------|-------|----------------------|------------------------|\n| GLM/Z.ai | glm-5 | $0.50 | $1.50 |\n| OpenAI | gpt-4o | $2.50 | $10.00 |\n| Anthropic | claude-sonnet-4-6 | $3.00 | $15.00 |\n| Gemini | gemini-2.0-flash | $0.10 | $0.40 |"
      }
    },
    {
      "title": "Total Requests (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 3 },
      "targets": [
        { "expr": "sum(increase(api_gateway_request_latency_seconds_count{path=\"/v1/messages\"}[24h]))", "legendFormat": "Sync", "refId": "A" },
        { "expr": "sum(increase(ai_worker_jobs_processed_total[24h]))", "legendFormat": "Async", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 100 }] }
        }
      }
    },
    {
      "title": "Est. Input Tokens (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 3 },
      "targets": [
        {
          "expr": "sum(increase(api_gateway_token_input_total[24h])) > 0 or on() vector(0)",
          "legendFormat": "Input tokens",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 100000 }] }
        }
      }
    },
    {
      "title": "Est. Output Tokens (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 3 },
      "targets": [
        {
          "expr": "sum(increase(api_gateway_token_output_total[24h])) > 0 or on() vector(0)",
          "legendFormat": "Output tokens",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 500000 }] }
        }
      }
    },
    {
      "title": "Est. Total Cost (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 3 },
      "targets": [
        {
          "expr": "(sum(increase(api_gateway_token_input_total{model=~\"glm.*\"}[24h])) / 1000000 * 0.5 + sum(increase(api_gateway_token_output_total{model=~\"glm.*\"}[24h])) / 1000000 * 1.5) > 0 or on() vector(0)",
          "legendFormat": "GLM Cost",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      }
    },
    {
      "title": "Request Volume Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        { "expr": "sum by (path) (rate(api_gateway_request_latency_seconds_count{path=~\"/v1/.*\"}[5m])) * 3600", "legendFormat": "{{path}} req/h", "refId": "A" },
        { "expr": "rate(ai_worker_jobs_processed_total[5m]) * 3600", "legendFormat": "{{provider}} async/h", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/h",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "title": "Token Usage by Model (24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "expr": "sum by (model) (increase(api_gateway_token_input_total[24h]))",
          "legendFormat": "{{model}} input",
          "refId": "A"
        },
        {
          "expr": "sum by (model) (increase(api_gateway_token_output_total[24h]))",
          "legendFormat": "{{model}} output",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stackBy": "model"
      }
    },
    {
      "title": "Est. Daily Cost by Model",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "sum by (model) (increase(api_gateway_token_input_total[24h])) / 1000000 * 0.5",
          "legendFormat": "{{model}} input cost",
          "refId": "A"
        },
        {
          "expr": "sum by (model) (increase(api_gateway_token_output_total[24h])) / 1000000 * 1.5",
          "legendFormat": "{{model}} output cost",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.5,
        "stackBy": "model"
      }
    },
    {
      "title": "Upstream 429s & Retries",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "increase(api_gateway_upstream_429_total[1h])",
          "legendFormat": "429s (1h)",
          "refId": "A"
        },
        {
          "expr": "increase(api_gateway_upstream_retries_total[1h])",
          "legendFormat": "Retries (1h)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Rate Limit Protection",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 23 },
      "options": {
        "mode": "markdown",
        "content": "### Rate Limit Protection\nRequests blocked by rate limiter = **cost savings** from preventing runaway API usage.\nWithout rate limiting, a single agent could consume the entire budget in minutes."
      }
    },
    {
      "title": "Rate Limited Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "rate(api_gateway_rate_limit_hits_total[5m]) * 3600",
          "legendFormat": "Gateway {{key}} req/h",
          "refId": "A"
        },
        {
          "expr": "rate(ai_worker_rate_limit_hits_total[5m]) * 3600",
          "legendFormat": "Worker {{provider}} req/h",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/h",
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "color": { "fixedColor": "orange", "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Provider Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "targets": [
        {
          "expr": "rate(api_gateway_error_total[5m]) * 3600",
          "legendFormat": "{{type}} errors/h",
          "refId": "A"
        },
        {
          "expr": "sum by (provider) (rate(ai_worker_provider_errors_total[5m])) * 3600",
          "legendFormat": "{{provider}} errors/h",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Limiter Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 34 },
      "targets": [
        { "expr": "api_gateway_active_connections", "legendFormat": "Active", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 9 }] }
        }
      }
    },
    {
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 34 },
      "targets": [
        { "expr": "api_gateway_queue_depth", "legendFormat": "Gateway", "refId": "A" },
        { "expr": "ai_worker_queue_depth", "legendFormat": "Worker", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }
        }
      }
    },
    {
      "title": "Rate Limit Hits Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 34 },
      "targets": [
        { "expr": "sum(api_gateway_rate_limit_hits_total)", "legendFormat": "Gateway", "refId": "A" },
        { "expr": "sum(ai_worker_rate_limit_hits_total)", "legendFormat": "Worker", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent-rate-limit", "cost"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "title": "Cost Calculator & Savings",
  "uid": "arl-cost",
  "version": 3
}
