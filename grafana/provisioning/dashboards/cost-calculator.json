{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "AI API Cost Estimator",
      "type": "text",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## AI API Cost Estimator\n| Model | Input (per 1M tokens) | Output (per 1M tokens) |\n|-------|----------------------|------------------------|\n| glm-5.1 / glm-5-turbo / glm-5 | $0.50 | $1.50 |\n| glm-4.7 / glm-4.6 | $0.30 | $1.00 |\n| glm-4.5 | $0.15 | $0.75 |"
      }
    },
    {
      "title": "Actual Cost (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum(increase(api_gateway_cost_total[24h])) or vector(0)", "legendFormat": "Total", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      }
    },
    {
      "title": "Est. Cost from Tokens (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "targets": [
        {
          "expr": "((sum(increase(api_gateway_token_input_total{model=~\"glm-5.1|glm-5-turbo|glm-5\"}[24h])) or vector(0)) * 0.5 + (sum(increase(api_gateway_token_output_total{model=~\"glm-5.1|glm-5-turbo|glm-5\"}[24h])) or vector(0)) * 1.5 + (sum(increase(api_gateway_token_input_total{model=~\"glm-4.7|glm-4.6\"}[24h])) or vector(0)) * 0.3 + (sum(increase(api_gateway_token_output_total{model=~\"glm-4.7|glm-4.6\"}[24h])) or vector(0)) * 1.0 + (sum(increase(api_gateway_token_input_total{model=\"glm-4.5\"}[24h])) or vector(0)) * 0.15 + (sum(increase(api_gateway_token_output_total{model=\"glm-4.5\"}[24h])) or vector(0)) * 0.75) / 1000000",
          "legendFormat": "Est. Total", "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD", "decimals": 2,
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      }
    },
    {
      "title": "Input Tokens (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "targets": [
        { "expr": "sum(increase(api_gateway_token_input_total[24h])) > 0 or on() vector(0)", "legendFormat": "Input", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "title": "Output Tokens (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "targets": [
        { "expr": "sum(increase(api_gateway_token_output_total[24h])) > 0 or on() vector(0)", "legendFormat": "Output", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "fixedColor": "green", "mode": "fixed" } } }
    },
    {
      "title": "Cost Trend (Hourly)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "showPoints": "never", "spanNulls": true },
          "unit": "currencyUSD"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (model) (increase(api_gateway_cost_total[1h])) or vector(0)", "legendFormat": "{{model}}", "refId": "A" }
      ]
    },
    {
      "title": "Cost by Model (24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum by (model) (increase(api_gateway_cost_total[24h])) or vector(0)", "legendFormat": "{{model}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } },
      "options": { "orientation": "horizontal", "groupWidth": 0.7, "barWidth": 0.5, "stackBy": "model" }
    },
    {
      "title": "Token Usage by Model (24h)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "sum by (model) (increase(api_gateway_token_input_total[24h]))", "legendFormat": "{{model}} input", "refId": "A" },
        { "expr": "sum by (model) (increase(api_gateway_token_output_total[24h]))", "legendFormat": "{{model}} output", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "orientation": "horizontal", "groupWidth": 0.7, "barWidth": 0.5, "stackBy": "model" }
    },
    {
      "title": "Total Requests (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "targets": [
        { "expr": "sum(increase(api_gateway_request_latency_seconds_count{path=\"/v1/messages\"}[24h]))", "legendFormat": "Sync", "refId": "A" },
        { "expr": "sum(increase(ai_worker_jobs_processed_total[24h]))", "legendFormat": "Async", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 100 }] } } }
    },
    {
      "title": "Model Fallback Distribution",
      "type": "barchart",
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 24 },
      "targets": [
        { "expr": "sum by (selected) (increase(api_gateway_model_fallback_total[24h]))", "legendFormat": "{{selected}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0 } },
      "options": { "orientation": "horizontal", "groupWidth": 0.7, "barWidth": 0.5 }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent-rate-limit", "cost"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "60s",
  "title": "Cost Calculator & Savings",
  "uid": "arl-cost",
  "version": 5
}
