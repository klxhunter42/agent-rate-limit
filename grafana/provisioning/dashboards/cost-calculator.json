  "panels": [
    {
      "title": "Cost Calculator - AI API Usage",
      "type": "text",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## AI API Cost Estimator\nEstimate costs based on actual token usage from the gateway.\n\n| Provider | Model | Input (per 1M tokens) | Output (per 1M tokens) |\n|----------|-------|----------------------|------------------------|\n| GLM/Z.ai | glm-5.1 | $0.50 | $1.50 |\n| GLM/Z.ai | glm-5-turbo | $0.50 | $1.50 |\n| GLM/Z.ai | glm-5 | $0.50 | $1.50 |\n| GLM/Z.ai | glm-4.7 | $0.30 | $1.00 |\n| GLM/Z.ai | glm-4.6 | $0.30 | $1.00 |\n| GLM/Z.ai | glm-4.5 | $0.15 | $0.75 |"
      }
    },
    {
      "title": "Actual Cost (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "expr": "sum(increase(api_gateway_cost_total[24h])) or vector(0)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "title": "Est. Total Cost from Tokens (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "targets": [
        {
          "expr": "((sum(increase(api_gateway_token_input_total{model=~\"glm-5.1|glm-5-turbo|glm-5\"}[24h])) or vector(0)) * 0.5 + (sum(increase(api_gateway_token_output_total{model=~\"glm-5.1|glm-5-turbo|glm-5\"}[24h])) or vector(0)) * 1.5 + (sum(increase(api_gateway_token_input_total{model=~\"glm-4.7|glm-4.6\"}[24h])) or vector(0)) * 0.3 + (sum(increase(api_gateway_token_output_total{model=~\"glm-4.7|glm-4.6\"}[24h])) or vector(0)) * 1.0 + (sum(increase(api_gateway_token_input_total{model=\"glm-4.5\"}[24h])) or vector(0)) * 0.15 + (sum(increase(api_gateway_token_output_total{model=\"glm-4.5\"}[24h])) or vector(0)) * 0.75) / 1000000",
          "legendFormat": "Est. Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
