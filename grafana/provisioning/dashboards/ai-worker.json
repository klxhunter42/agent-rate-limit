{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Jobs Processed / Failed / Retried",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(ai_worker_jobs_processed_total[$__rate_interval])", "legendFormat": "Processed/s ({{provider}})", "refId": "A" },
        { "expr": "rate(ai_worker_jobs_failed_total[$__rate_interval])", "legendFormat": "Failed/s", "refId": "B" },
        { "expr": "rate(ai_worker_jobs_retried_total[$__rate_interval])", "legendFormat": "Retried/s", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10, "spanNulls": true }, "noValue": "0" }
      }
    },
    {
      "title": "Total Jobs",
      "type": "stat",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "sum(ai_worker_jobs_processed_total) or on() vector(0)", "legendFormat": "Processed", "refId": "A" },
        { "expr": "sum(ai_worker_jobs_failed_total) or on() vector(0)", "legendFormat": "Failed", "refId": "B" },
        { "expr": "sum(ai_worker_jobs_retried_total) or on() vector(0)", "legendFormat": "Retried", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "noValue": "0", "color": { "mode": "palette-classic" } },
        "overrides": [{ "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }]
      }
    },
    {
      "title": "Queue Depth Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "targets": [
        { "expr": "ai_worker_queue_depth", "legendFormat": "Queue Depth", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "spanNulls": true },
          "noValue": "0",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }
        }
      }
    },
    {
      "title": "Active Workers",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 9 },
      "targets": [
        { "expr": "ai_worker_active or on() vector(0)", "legendFormat": "Active", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 50, "noValue": "0", "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }
      }
    },
    {
      "title": "Error Rate %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 9 },
      "targets": [
        { "expr": "clamp_max(rate(ai_worker_jobs_failed_total[$__rate_interval]) / (rate(ai_worker_jobs_processed_total[$__rate_interval]) > 0) * 100, 100) or on() vector(0)", "legendFormat": "Error %", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "noValue": "0", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } }
      }
    },
    {
      "title": "Rate Limit Hits",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 9 },
      "targets": [
        { "expr": "sum(ai_worker_rate_limit_hits_total) or on() vector(0)", "legendFormat": "Total", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "title": "Total Provider Errors",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 9 },
      "targets": [
        { "expr": "sum(ai_worker_provider_errors_total) or on() vector(0)", "legendFormat": "Errors", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "noValue": "0", "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "title": "Token Usage - Input by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        { "expr": "sum by (model) (rate(ai_worker_token_input_total[$__rate_interval]))", "legendFormat": "{{model}} input", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "tokps", "noValue": "0", "custom": { "spanNulls": true } } }
    },
    {
      "title": "Token Usage - Output by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        { "expr": "sum by (model) (rate(ai_worker_token_output_total[$__rate_interval]))", "legendFormat": "{{model}} output", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "tokps", "noValue": "0", "custom": { "spanNulls": true } } }
    },
    {
      "title": "Provider Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, provider) (rate(ai_worker_provider_latency_seconds_bucket[$__rate_interval])))", "legendFormat": "{{provider}} p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(ai_worker_provider_latency_seconds_bucket[$__rate_interval])))", "legendFormat": "{{provider}} p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le, provider) (rate(ai_worker_provider_latency_seconds_bucket[$__rate_interval])))", "legendFormat": "{{provider}} p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "noValue": "-", "custom": { "spanNulls": true } } }
    },
    {
      "title": "Worker Process Memory (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"ai-worker\"}", "legendFormat": "RSS", "refId": "A" },
        { "expr": "process_virtual_memory_bytes{job=\"ai-worker\"}", "legendFormat": "Virtual", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "noValue": "-", "custom": { "spanNulls": true } } }
    },
    {
      "title": "Worker CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total{job=\"ai-worker\"}[$__rate_interval])", "legendFormat": "CPU seconds/s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "core", "noValue": "-", "custom": { "spanNulls": true } } }
    },
    {
      "title": "Provider Errors by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 },
      "targets": [
        { "expr": "rate(ai_worker_provider_errors_total[$__rate_interval])", "legendFormat": "{{provider}} errors/s", "refId": "A" },
        { "expr": "rate(ai_worker_rate_limit_hits_total[$__rate_interval])", "legendFormat": "{{provider}} rate-limited/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "noValue": "0", "custom": { "spanNulls": true } } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent-rate-limit", "worker"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "title": "AI Worker - Detailed",
  "uid": "arl-worker",
  "version": 3
}
