{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate by Path",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (path, method, status) (rate(api_gateway_request_latency_seconds_count[5m]))",
          "legendFormat": "{{method}} {{path}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(api_gateway_request_latency_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.90, sum by (le) (rate(api_gateway_request_latency_seconds_bucket[5m])))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(api_gateway_request_latency_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "C" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(api_gateway_request_latency_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "api_gateway_active_connections", "legendFormat": "Active", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 30 } } }
    },
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "api_gateway_queue_depth", "legendFormat": "Queue Depth", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }
        }
      }
    },
    {
      "title": "Token Usage - Input by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "rate(api_gateway_token_input_total[5m])", "legendFormat": "{{model}} input", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "tokps", "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Token Usage - Output by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "rate(api_gateway_token_output_total[5m])", "legendFormat": "{{model}} output", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "tokps", "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Request Latency Heatmap (avg by path)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (path) (rate(api_gateway_request_latency_seconds_sum[5m])) / sum by (path) (rate(api_gateway_request_latency_seconds_count[5m]))",
          "legendFormat": "{{path}} avg",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Upstream 429s & Retries",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "rate(api_gateway_upstream_429_total[5m])", "legendFormat": "429s/s", "refId": "A" },
        { "expr": "rate(api_gateway_upstream_retries_total[5m])", "legendFormat": "Retries/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Errors by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        { "expr": "rate(api_gateway_error_total[5m])", "legendFormat": "{{type}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Rate Limit Hits by Key",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "targets": [
        { "expr": "rate(api_gateway_rate_limit_hits_total[5m])", "legendFormat": "{{key}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "fixedColor": "orange", "mode": "palette-classic" } } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["agent-rate-limit", "gateway"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "title": "API Gateway - Detailed",
  "uid": "arl-gateway",
  "version": 2
}
