FROM node:22-slim

RUN apt-get update && apt-get install -y git curl python3 && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

COPY entrypoint-claude.sh /usr/local/bin/entrypoint-claude.sh
RUN chmod +x /usr/local/bin/entrypoint-claude.sh

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/entrypoint-claude.sh"]
