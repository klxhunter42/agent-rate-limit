# =============================================================================
# Multi-Agent AI System - Environment Configuration
# Copy this to .env and fill in your API keys
#
# IMPORTANT: If you don't use a provider, either leave the value empty
# or remove the line entirely. The system will skip providers without keys.
# =============================================================================

# --- API Gateway ---
GATEWAY_PORT=8080
GLOBAL_RATE_LIMIT=100
AGENT_RATE_LIMIT=5
WORKER_POOL_SIZE=100
UPSTREAM_URL=https://api.z.ai/api/anthropic
STREAM_TIMEOUT=300s
MAX_REQUEST_BODY=10485760

# --- Z.AI (Primary Provider) ---
# Comma-separated keys for rotation. Also registerable via Dashboard UI (Providers > Z.AI).
UPSTREAM_API_KEYS=
UPSTREAM_RPM_LIMIT=40

# Per-model upstream concurrency limits (model:limit comma-separated)
UPSTREAM_MODEL_LIMITS=glm-5.1:1,glm-5-turbo:1,glm-5:2,glm-4.7:2,glm-4.6:3,glm-4.5:10
UPSTREAM_DEFAULT_LIMIT=2
UPSTREAM_GLOBAL_LIMIT=15

# Upstream retry on 429 rate-limit errors
UPSTREAM_MAX_RETRIES=3
UPSTREAM_RETRY_BACKOFF=500ms
UPSTREAM_PROBE_MULTIPLIER=5

# Token efficiency features
ENABLE_PROMPT_INJECTION=true
ENABLE_RESPONSE_TRIM=true
ENABLE_SMART_MAX_TOKENS=true
# PROMPT_INJECTION_TEXT=

# --- Default Request Values ---
DEFAULT_MODEL=glm-5
DEFAULT_PROVIDER=glm
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1024

# --- Quota Settings ---
QUOTA_CACHE_TTL=30s
QUOTA_DAILY_BUDGET=57600
QUOTA_BLOCK_PCT=95
QUOTA_REDIS_POOL_SIZE=5
QUOTA_REDIS_MIN_IDLE=2
# PROVIDER_MODEL_PREFIXES=zai:glm-;anthropic:claude-;claude:claude-;openai:gpt-,o3,o4-;gemini:gemini-;gemini-oauth:gemini-;openrouter:or-;qwen:qwen-

# --- Anthropic ---
# ANTHROPIC_UPSTREAM_BASE=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01

# --- Claude OAuth ---
# CLAUDE_OAUTH_CLIENT_ID=
# CLAUDE_UPSTREAM_BASE=https://claude.ai

# --- Gemini ---
# GEMINI_UPSTREAM_BASE=https://generativelanguage.googleapis.com
# GEMINI_CODEASSIST_BASE=https://cloudcode-pa.googleapis.com/v1internal
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com
GEMINI_CODEASSIST_ENDPOINT=https://cloudcode-pa.googleapis.com/v1internal
GEMINI_DEFAULT_MODEL=models/gemini-2.5-flash-preview-05-20
# GEMINI_OAUTH_CLIENT_ID=
# GEMINI_OAUTH_CLIENT_SECRET=

# --- OpenAI ---
# OPENAI_UPSTREAM_BASE=https://api.openai.com

# --- OpenRouter ---
# OPENROUTER_UPSTREAM_BASE=https://openrouter.ai/api

# --- DeepSeek ---
# DEEPSEEK_UPSTREAM_BASE=https://api.deepseek.com

# --- Kimi (Moonshot) ---
# KIMI_UPSTREAM_BASE=https://api.moonshot.cn/v1

# --- HuggingFace ---
# HUGGINGFACE_UPSTREAM_BASE=https://api-inference.huggingface.co/models

# --- Ollama ---
# OLLAMA_UPSTREAM_BASE=http://localhost:11434

# --- AGY (Antigravity) ---
# AGY_UPSTREAM_BASE=https://antigravity.com

# --- Cursor ---
# CURSOR_UPSTREAM_BASE=https://api2.cursor.sh

# --- CodeBuddy ---
# CODEBUDDY_UPSTREAM_BASE=https://api.codebuddy.io

# --- Kilo ---
# KILO_UPSTREAM_BASE=https://api.kilo.ai

# --- Qwen ---
# QWEN_API_KEY=
# QWEN_UPSTREAM_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Adaptive Limiter ---
# MODEL_PRIORITY=glm-5.1:100,glm-5-turbo:90,glm-5:80,glm-4.7:70,glm-4.6:60,glm-4.5:50
ANOMALY_COOLDOWN_SEC=5
ANOMALY_Z_THRESHOLD=2.0

# --- Dashboard Auth (optional) ---
# DASHBOARD_API_KEY=

# --- PasteGuard Privacy Masking ---
PASTEGUARD_ENABLED=true
PASTEGUARD_SECRETS_ENABLED=true
# PASTEGUARD_SECRET_ENTITIES=OPENSSH_PRIVATE_KEY,PEM_PRIVATE_KEY,API_KEY_SK,API_KEY_AWS,API_KEY_GITHUB,JWT_TOKEN,BEARER_TOKEN
PASTEGUARD_MAX_SCAN_CHARS=200000
PASTEGUARD_PII_ENABLED=true
PASTEGUARD_PRESIDIO_URL=http://arl-presidio:3000
PASTEGUARD_PII_SCORE_THRESHOLD=0.7
# PASTEGUARD_PII_ENTITIES=PERSON,EMAIL_ADDRESS,PHONE_NUMBER
PASTEGUARD_PII_LANGUAGE=en

# --- Docker Platform ---
DOCKER_PLATFORM=linux/arm64

# --- Observability ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme

# --- Dashboard UI ---
DASHBOARD_PORT=8082
