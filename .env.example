# =============================================================================
# Multi-Agent AI System - Environment Configuration
# Copy this to .env and fill in your API keys
#
# IMPORTANT: If you don't use a provider, either leave the value empty
# or remove the line entirely. The system will skip providers without keys.
# =============================================================================

# --- API Gateway ---
GATEWAY_PORT=8080
GLOBAL_RATE_LIMIT=100
AGENT_RATE_LIMIT=5
WORKER_POOL_SIZE=100
UPSTREAM_URL=https://api.z.ai/api/anthropic
STREAM_TIMEOUT=300s

# Per-model upstream concurrency limits (model:limit comma-separated)
# If a model is not listed, UPSTREAM_DEFAULT_LIMIT is used.
UPSTREAM_MODEL_LIMITS=glm-5.1:1,glm-5-turbo:1,glm-5:2,glm-4.7:2,glm-4.6:3
UPSTREAM_DEFAULT_LIMIT=1
UPSTREAM_GLOBAL_LIMIT=9

# Per-provider RPM limits (prevent 429 by pacing requests)
# glm:5 = max 5 requests per minute to Z.ai (single key budget)
PROVIDER_RPM_LIMITS=glm:5

# Upstream retry on 429 rate-limit errors
UPSTREAM_MAX_RETRIES=3
UPSTREAM_RETRY_BACKOFF=500ms

# Token efficiency features
ENABLE_PROMPT_INJECTION=true
ENABLE_RESPONSE_TRIM=true
ENABLE_SMART_MAX_TOKENS=true
# Custom system prompt injection text (leave empty for default terse rules)
# PROMPT_INJECTION_TEXT=

# Multi-key rotation pool (comma-separated upstream API keys)
# When set, the gateway rotates keys to avoid per-key RPM limits.
# UPSTREAM_API_KEYS=sk-key1,sk-key2,sk-key3
UPSTREAM_RPM_LIMIT=40

# --- Dragonfly ---
DRAGONFLY_MAX_MEMORY=6gb

# --- Rate Limiter ---
RATE_LIMITER_CAPACITY=1000
RATE_LIMITER_REFILL_RATE=100

# --- AI Worker ---
WORKER_CONCURRENCY=50
MAX_RETRIES=3
BASE_BACKOFF=1.0
RESULT_TTL=600

# --- GLM / Z.ai (Primary Provider) ---
# Comma-separated keys for key rotation
GLM_API_KEYS=
GLM_ENDPOINT=https://api.z.ai/api/anthropic

# --- OpenAI ---
# Uncomment and fill if using OpenAI. Remove or leave empty to skip.
# OPENAI_API_KEYS=sk-openai-key-1,sk-openai-key-2

# --- Anthropic ---
# Uncomment and fill if using Anthropic directly. Remove or leave empty to skip.
# ANTHROPIC_API_KEYS=sk-ant-key-1,sk-ant-key-2

# --- Google Gemini ---
# Uncomment and fill if using Google Gemini. Remove or leave empty to skip.
# GEMINI_API_KEYS=gemini-key-1,gemini-key-2

# --- OpenRouter ---
# Uncomment and fill if using OpenRouter. Remove or leave empty to skip.
# OPENROUTER_API_KEYS=or-key-1,or-key-2

# --- Docker Platform ---
# linux/arm64 for Apple Silicon / ARM servers
# linux/amd64 for Intel / AMD servers
DOCKER_PLATFORM=linux/arm64

# --- Observability ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=klxhunter
